{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metadata.schema.json",
  "title": "MDDataNet Hub dataset metadata",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "dataset_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "task": {
      "$ref": "task.schema.json"
    },
    "system": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "system_type": {
          "type": "string",
          "enum": [
            "protein_ligand",
            "protein",
            "protein_protein",
            "peptide",
            "nucleic_acid",
            "membrane",
            "solvent",
            "small_molecule",
            "other"
          ]
        },
        "protein": {
          "type": "string"
        },
        "ligand": {
          "type": "string"
        }
      },
      "required": [
        "system_type"
      ]
    },
    "storage_profile": {
      "type": "string",
      "enum": [
        "metadata_only",
        "compressed",
        "external_coordinates",
        "full_package_external"
      ]
    },
    "coordinate_storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "included": {
          "type": "boolean"
        },
        "external": {
          "type": "boolean"
        },
        "format": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "included",
        "external"
      ]
    },
    "splits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy": {
          "type": "string",
          "enum": [
            "trajectory_split",
            "run_split",
            "temporal_split",
            "protein_family_split",
            "ligand_scaffold_split"
          ]
        },
        "train": {
          "type": "integer",
          "minimum": 0
        },
        "validation": {
          "type": "integer",
          "minimum": 0
        },
        "test": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "policy"
      ]
    },
    "statistics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "num_trajectories": {
          "type": "integer",
          "minimum": 0
        },
        "total_frames": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "num_trajectories",
        "total_frames"
      ]
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "citation": {
      "type": "string"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object"
    }
  },
  "required": [
    "dataset_name",
    "version",
    "task",
    "system",
    "storage_profile",
    "coordinate_storage",
    "splits",
    "statistics",
    "license"
  ]
}
